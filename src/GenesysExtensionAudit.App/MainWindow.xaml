<Window x:Class="GenesysExtensionAudit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Genesys Cloud Extension Audit"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1F2937" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Genesys Cloud Extension Audit"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Status:" Foreground="#D1D5DB" />
                        <TextBlock Text="{Binding StatusText}" Foreground="#E5E7EB" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="Help"
                            Margin="0,0,0,0"
                            Padding="10,4"
                            Command="{Binding HelpCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Shell navigation -->
        <TabControl DockPanel.Dock="Top"
                    ItemsSource="{Binding NavigationItems}"
                    SelectedItem="{Binding CurrentItem, Mode=TwoWay}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentPresenter Content="{Binding Content}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#F3F4F6" Padding="8">
            <TextBlock Text="{Binding FooterText}" Foreground="#374151" />
        </Border>

    </DockPanel>
</Window>
