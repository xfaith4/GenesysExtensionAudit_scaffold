<UserControl x:Class="GenesysExtensionAudit.Views.RunAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GenesysExtensionAudit.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type vm:RunAuditViewModel}}"
             d:DesignHeight="600" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="720">

            <!-- ─── Title ─── -->
            <TextBlock Text="Run Audit"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20" />

            <!-- ─── Configuration ─── -->
            <GroupBox Header="Configuration" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Page Size"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical">
                        <TextBox Text="{Binding PageSize, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100"
                                 HorizontalAlignment="Left" />
                        <TextBlock Text="Number of records per API page (1–500). Default: 100."
                                   Foreground="#6B7280" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Include Inactive Users"
                               VerticalAlignment="Center" />
                    <CheckBox Grid.Row="2" Grid.Column="1"
                              IsChecked="{Binding IncludeInactive}"
                              VerticalAlignment="Center"
                              Content="Include users with state = inactive" />
                </Grid>
            </GroupBox>

            <!-- ─── Audit Paths ─── -->
            <GroupBox Header="Audit Paths" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="Select All"
                              IsChecked="{Binding SelectAllAudits}"
                              FontWeight="SemiBold"
                              Margin="0,0,0,8" />

                    <WrapPanel>
                        <CheckBox Content="Extensions"
                                  IsChecked="{Binding RunExtensionAudit}"
                                  Margin="0,0,18,8" />
                        <CheckBox Content="Groups"
                                  IsChecked="{Binding RunGroupAudit}"
                                  Margin="0,0,18,8" />
                        <CheckBox Content="Queues"
                                  IsChecked="{Binding RunQueueAudit}"
                                  Margin="0,0,18,8" />
                        <CheckBox Content="Flows"
                                  IsChecked="{Binding RunFlowAudit}"
                                  Margin="0,0,18,8" />
                        <CheckBox Content="Inactive Users"
                                  IsChecked="{Binding RunInactiveUserAudit}"
                                  Margin="0,0,18,8" />
                        <CheckBox Content="DIDs"
                                  IsChecked="{Binding RunDidAudit}"
                                  Margin="0,0,18,8" />
                        <CheckBox Content="Audit Logs"
                                  IsChecked="{Binding RunAuditLogs}"
                                  Margin="0,0,18,8" />
                    </WrapPanel>

                    <TextBlock Text="Choose one or more paths to run in this audit pass."
                               Foreground="#6B7280"
                               FontSize="11" />

                    <Border Margin="0,10,0,0" Padding="10" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4"
                            Visibility="{Binding RunAuditLogs, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Audit Logs Catalog Entity" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox Width="320"
                                          ItemsSource="{Binding AuditLogEntities}"
                                          SelectedItem="{Binding SelectedAuditLogEntity}"
                                          IsEnabled="{Binding IsAuditLogSelectionEnabled}" />
                                <Button Content="Refresh"
                                        Command="{Binding RefreshAuditCatalogCommand}"
                                        Margin="8,0,0,0"
                                        Padding="10,4" />
                            </StackPanel>
                            <TextBlock Text="Choose one catalog entity or keep All Catalog Entities."
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </GroupBox>

            <!-- ─── Actions ─── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="▶  Start Audit"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding CanStart}"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Background="#1D4ED8"
                        Foreground="White"
                        FontWeight="SemiBold" />

                <Button Content="⏹  Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding CanCancel}"
                        Padding="16,8" />
            </StackPanel>

            <!-- ─── Progress ─── -->
            <GroupBox Header="Progress" Padding="12" Margin="0,0,0,16"
                      Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding ProgressPercent, Mode=OneWay}"
                                 Height="16"
                                 Margin="0,0,0,8" />
                    <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                               HorizontalAlignment="Right"
                               Foreground="#374151"
                               FontSize="12"
                               Margin="0,-4,0,6" />
                    <TextBlock Text="{Binding ProgressMessage}"
                               Foreground="#374151"
                               TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>

            <!-- ─── Status ─── -->
            <Border Background="#F3F4F6" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status: " FontWeight="SemiBold" Foreground="#374151" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#374151" />
                </StackPanel>
            </Border>

            <!-- ─── Error ─── -->
            <Border Background="#FEF2F2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Error" FontWeight="SemiBold" Foreground="#B91C1C" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#B91C1C"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
