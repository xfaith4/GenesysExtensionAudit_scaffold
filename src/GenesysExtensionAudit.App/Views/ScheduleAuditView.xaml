<UserControl x:Class="GenesysExtensionAudit.Views.ScheduleAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GenesysExtensionAudit.ViewModels"
             xmlns:sched="clr-namespace:GenesysExtensionAudit.Scheduling"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type vm:ScheduleAuditViewModel}}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="900">

            <TextBlock Text="Schedule Audits"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20" />

            <GroupBox Header="Schedule Configuration" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Schedule Name" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ScheduleName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Recurrence" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              SelectedValue="{Binding SelectedRecurrence}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="One-time" Tag="{x:Static sched:ScheduledRecurrenceType.Once}" />
                        <ComboBoxItem Content="Daily" Tag="{x:Static sched:ScheduledRecurrenceType.Daily}" />
                        <ComboBoxItem Content="Weekly" Tag="{x:Static sched:ScheduledRecurrenceType.Weekly}" />
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Start Date" VerticalAlignment="Center" />
                    <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding StartDate}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Start Time (HH:mm)" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}" Width="120" />

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Weekly Days" VerticalAlignment="Top" />
                    <WrapPanel Grid.Row="8" Grid.Column="1"
                               Visibility="{Binding IsWeeklyRecurrence, Converter={StaticResource BoolToVisibility}}">
                        <CheckBox Content="Mon" IsChecked="{Binding WeeklyMonday}" Margin="0,0,10,0" />
                        <CheckBox Content="Tue" IsChecked="{Binding WeeklyTuesday}" Margin="0,0,10,0" />
                        <CheckBox Content="Wed" IsChecked="{Binding WeeklyWednesday}" Margin="0,0,10,0" />
                        <CheckBox Content="Thu" IsChecked="{Binding WeeklyThursday}" Margin="0,0,10,0" />
                        <CheckBox Content="Fri" IsChecked="{Binding WeeklyFriday}" Margin="0,0,10,0" />
                        <CheckBox Content="Sat" IsChecked="{Binding WeeklySaturday}" Margin="0,0,10,0" />
                        <CheckBox Content="Sun" IsChecked="{Binding WeeklySunday}" />
                    </WrapPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="Run As Credentials" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RunAsUserName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Password" VerticalAlignment="Center" />
                    <PasswordBox Grid.Row="2" Grid.Column="1"
                                 PasswordChanged="PasswordBox_OnPasswordChanged" />
                </Grid>
            </GroupBox>

            <GroupBox Header="Audit Selection + Options" Padding="12" Margin="0,0,0,14">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <CheckBox Content="Extensions" IsChecked="{Binding RunExtensionAudit}" Margin="0,0,18,8" />
                        <CheckBox Content="Groups" IsChecked="{Binding RunGroupAudit}" Margin="0,0,18,8" />
                        <CheckBox Content="Queues" IsChecked="{Binding RunQueueAudit}" Margin="0,0,18,8" />
                        <CheckBox Content="Flows" IsChecked="{Binding RunFlowAudit}" Margin="0,0,18,8" />
                        <CheckBox Content="Inactive Users" IsChecked="{Binding RunInactiveUserAudit}" Margin="0,0,18,8" />
                        <CheckBox Content="DIDs" IsChecked="{Binding RunDidAudit}" Margin="0,0,18,8" />
                        <CheckBox Content="Audit Logs" IsChecked="{Binding RunAuditLogs}" Margin="0,0,18,8" />
                    </WrapPanel>

                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Page Size" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PageSize}" />

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Include Inactive Users" VerticalAlignment="Center" />
                        <CheckBox Grid.Row="0" Grid.Column="3" IsChecked="{Binding IncludeInactive}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Stale Flow Days" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding StaleFlowDays}" />

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Inactive User Days" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding InactiveUserDays}" />
                    </Grid>

                    <Border Margin="0,10,0,0" Padding="10" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4"
                            Visibility="{Binding RunAuditLogs, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Audit Logs Catalog Entity" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox Width="320"
                                          ItemsSource="{Binding AuditLogEntities}"
                                          SelectedItem="{Binding SelectedAuditLogEntity}" />
                                <Button Content="Refresh"
                                        Command="{Binding RefreshAuditCatalogCommand}"
                                        Margin="8,0,0,0"
                                        Padding="10,4" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Lookback Hours" VerticalAlignment="Center" />
                                <TextBox Width="80" Margin="8,0,0,0" Text="{Binding AuditLogLookbackHours}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Button Content="Create Scheduled Task"
                        Command="{Binding CreateScheduledTaskCommand}"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Background="#1D4ED8"
                        Foreground="White"
                        FontWeight="SemiBold" />

                <Button Content="Refresh List"
                        Command="{Binding RefreshScheduledTasksCommand}"
                        Padding="16,8"
                        Margin="0,0,10,0" />

                <Button Content="Delete Selected Task"
                        Command="{Binding DeleteScheduledTaskCommand}"
                        Padding="16,8" />
            </StackPanel>

            <GroupBox Header="Scheduled Tasks" Padding="12" Margin="0,0,0,12">
                <DataGrid ItemsSource="{Binding ScheduledTasks}"
                          SelectedItem="{Binding SelectedTask}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Task Name" Binding="{Binding TaskName}" Width="2*" />
                        <DataGridTextColumn Header="Next Run" Binding="{Binding NextRunTime}" Width="*" />
                        <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunTime}" Width="*" />
                        <DataGridTextColumn Header="Last Result" Binding="{Binding LastResult}" Width="*" />
                        <DataGridTextColumn Header="Recurrence" Binding="{Binding Recurrence}" Width="*" />
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Border Background="#F3F4F6" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status: " FontWeight="SemiBold" Foreground="#374151" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#374151" />
                </StackPanel>
            </Border>

            <Border Background="#FEF2F2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Error" FontWeight="SemiBold" Foreground="#B91C1C" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
