{
  "Genesys": {
    "Region": "usw2.pure.cloud",
    "PageSize": 100,
    "IncludeInactive": false,
    "MaxRequestsPerSecond": 3
  },

  "GenesysOAuth": {
    "ClientId": "",
    "ClientSecret": ""
  },

  "Audit": {
    "StaleFlowThresholdDays": 90,
    "InactiveUserThresholdDays": 90,
    "IncludeInactiveUsers": false
  },

  "Export": {
    "OutputDirectory": "reports",
    "FilePrefix": "GenesysAudit"
  },

  "SharePoint": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "SiteUrl": "",
    "FolderPath": "Shared Documents/GenesysAudit"
  },

  "Scheduling": {
    "TaskFolderPath": "\\GenesysExtensionAudit\\",
    "TaskNamePrefix": "GenesysExtensionAudit_",
    "RunnerExecutablePath": ""
  },

  "Logging": {
    "MinimumLevel": "Information",
    "EnableConsole": true,
    "EnableFile": true,
    "FileMinimumLevel": "Information",
    "LogDirectory": "logs",
    "RetainedFileCount": 14,
    "EnableSerilogSelfLog": false
  }
}
