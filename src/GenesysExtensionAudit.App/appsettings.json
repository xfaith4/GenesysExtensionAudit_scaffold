{
  "Genesys": {
    "Region": "usw2.pure.cloud",
    "PageSize": 100,
    "IncludeInactive": false,
    "MaxRequestsPerSecond": 3
  },

  "GenesysOAuth": {
    "ClientId": "",
    "ClientSecret": ""
  },

  "Audit": {
    "StaleFlowThresholdDays": 90,
    "InactiveUserThresholdDays": 90,
    "IncludeInactiveUsers": false,
    "RunOperationalEventLogs": false,
    "OperationalEventLookbackDays": 7,
    "RunOutboundEvents": false
  },

  "Export": {
    "OutputDirectory": "reports",
    "FilePrefix": "GenesysAudit"
  },

  "SharePoint": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "SiteUrl": "",
    "FolderPath": "Shared Documents/GenesysAudit"
  },

  "GitHub": {
    "Token": "",
    "Owner": "",
    "Repository": "",
    "Branch": "main",
    "FolderPath": "audit-reports",
    "CommitMessage": "chore: add audit report {fileName}"
  },

  "Scheduling": {
    "TaskFolderPath": "\\GenesysExtensionAudit\\",
    "TaskNamePrefix": "GenesysExtensionAudit_",
    "RunnerExecutablePath": ""
  },

  "Logging": {
    "MinimumLevel": "Information",
    "EnableConsole": true,
    "EnableFile": true,
    "FileMinimumLevel": "Information",
    "LogDirectory": "logs",
    "RetainedFileCount": 8,
    "MaxFileSizeMb": 20,
    "RetainedDays": 8,
    "EnableSerilogSelfLog": false
  }
}
